digraph SpecAudit {
    graph [
        goal="Audit the coreys-attractor implementation against the attractor spec in ../attractor/attractor-spec.md and report all gaps",
        label="Attractor Spec Audit"
    ]
    rankdir=LR

    start  [shape=Mdiamond, label="Start"]
    exit   [shape=Msquare,  label="Done"]

    // ── Section 2: DOT DSL Schema ─────────────────────────────────────────────
    audit_dsl [
        label="Audit DOT DSL Schema",
        prompt="Audit Section 2 (DOT DSL Schema) of ../attractor/attractor-spec.md against the implementation in src/main/kotlin/attractor/dot/. Check: (1) BNF grammar coverage in Lexer.kt and Parser.kt, (2) all graph-level attributes from Section 2.5 (goal, label, model_stylesheet, default_max_retry, retry_target, fallback_retry_target, default_fidelity) are parsed in DotModel.kt, (3) all node attributes from Section 2.6 are parsed, (4) all edge attributes from Section 2.7 are parsed, (5) shape-to-handler mapping in Section 2.8 matches HandlerRegistry.kt, (6) chained edge expansion works, (7) subgraph scoping per Section 2.10 is implemented. Report IMPLEMENTED or NOT IMPLEMENTED for each item."
    ]

    // ── Section 3: Pipeline Execution Engine ──────────────────────────────────
    audit_engine [
        label="Audit Execution Engine",
        prompt="Audit Section 3 (Pipeline Execution Engine) against src/main/kotlin/attractor/engine/Engine.kt. Check: (1) 5-phase lifecycle PARSE->VALIDATE->INITIALIZE->EXECUTE->FINALIZE in Engine.run(), (2) core execution loop matches Section 3.2 pseudocode exactly (Steps 1-8), (3) edge selection algorithm in EdgeSelector.kt implements all 5 steps from Section 3.3, (4) goal gate enforcement per Section 3.4, (5) retry logic per Section 3.5: max_retries node attr, fallback to graph default_max_retry (CRITICAL: RetryPolicy.fromNode ignores graphDefaultMaxRetry param), (6) backoff presets NONE/STANDARD/AGGRESSIVE/LINEAR/PATIENT in RetryPolicy.kt, (7) failure routing Section 3.7 (fail edge -> retry_target -> fallback_retry_target -> terminate), (8) loop_restart full re-launch with fresh log dir vs current impl that just continues. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Section 4: Node Handlers ──────────────────────────────────────────────
    audit_handlers [
        label="Audit Node Handlers",
        prompt="Audit Section 4 (Node Handlers) against src/main/kotlin/attractor/handlers/. Check each handler: (1) StartHandler: no-op returns SUCCESS, (2) ExitHandler: no-op returns SUCCESS, (3) CodergenHandler Section 4.5: CRITICAL - Main.kt always passes SimulationBackend even when ANTHROPIC_API_KEY is set; real LLM client from llm/Client.kt is never wired into CodergenHandler, (4) WaitForHumanHandler Section 4.6: accelerator key parsing, timeout/skip handling, (5) ConditionalHandler Section 4.7: correct no-op, (6) ParallelHandler Section 4.8: CRITICAL - does not execute subgraph traversal, just returns success without calling branch node handlers; error_policy fail_fast not implemented, (7) FanInHandler Section 4.9: heuristic select works but LLM-based evaluation missing, (8) ToolHandler Section 4.10, (9) ManagerLoopHandler Section 4.11: CRITICAL - no child pipeline autostart (stack.child_autostart not implemented). Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Section 5: State and Context ─────────────────────────────────────────
    audit_state [
        label="Audit State & Context",
        prompt="Audit Section 5 (State and Context) against src/main/kotlin/attractor/state/. Check: (1) Context thread safety with ReentrantReadWriteLock, (2) all built-in context keys set by engine (outcome, preferred_label, graph.goal, current_node, last_stage, last_response, internal.retry_count.*), (3) Outcome fields match spec (status, preferred_label, suggested_next_ids, context_updates, notes, failure_reason), (4) all StageStatus values (SUCCESS, PARTIAL_SUCCESS, RETRY, FAIL, SKIPPED), (5) Checkpoint.kt saves/loads correctly, (6) CRITICAL: checkpoint resume not implemented - EngineConfig has resume=false but Engine.run() never loads from existing checkpoint, (7) ArtifactStore.kt implements file-backing for large artifacts, (8) auto_status node attribute parsed but NEVER checked in engine executeNodeWithRetry, (9) timeout node attribute parsed but NEVER enforced in engine. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Section 6: Human-in-the-Loop ─────────────────────────────────────────
    audit_human [
        label="Audit Human-in-the-Loop",
        prompt="Audit Section 6 (Human-in-the-Loop / Interviewer Pattern) against src/main/kotlin/attractor/human/. Check: (1) Interviewer interface, (2) ConsoleInterviewer for interactive CLI, (3) AutoApproveInterviewer, (4) QueueInterviewer for programmatic testing, (5) RecordingInterviewer, (6) CallbackInterviewer, (7) Question/Answer/Choice types, (8) WaitForHumanHandler accelerator key parsing patterns ([K], K), K -), (9) human.default_choice fallback on timeout. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Section 7: Validation and Linting ────────────────────────────────────
    audit_lint [
        label="Audit Validation & Linting",
        prompt="Audit Section 7 (Validation and Linting) against src/main/kotlin/attractor/lint/. Check each lint rule exists: start_node, terminal_node (exit node), reachability, edge_target_exists, start_no_incoming, exit_no_outgoing, condition_syntax, stylesheet_syntax, type_known, fidelity_valid, retry_target_exists, goal_gate_has_retry, prompt_on_llm_nodes. Verify Validator.kt wires them up. Check that errors abort and warnings allow continuation. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Section 8: Model Stylesheet ───────────────────────────────────────────
    audit_stylesheet [
        label="Audit Model Stylesheet",
        prompt="Audit Section 8 (Model Stylesheet) against src/main/kotlin/attractor/style/Stylesheet.kt. Check: (1) CSS-like syntax with * (universal), #id, .class selectors, (2) specificity ordering (universal=0, class=1, id=2), (3) only sets properties not already explicitly set (no-override rule), (4) llm_model, llm_provider, reasoning_effort as valid properties, (5) StylesheetApplicationTransform applies it, (6) subgraph class derivation: lowercase, spaces->hyphens, strip non-alphanumeric. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Sections 9 & 10: Transforms and Condition Language ───────────────────
    audit_transforms [
        label="Audit Transforms & Conditions",
        prompt="Audit Section 9 (Transforms) and Section 10 (Condition Expression Language). For transforms: (1) Transform interface, (2) VariableExpansionTransform expands $goal, (3) StylesheetApplicationTransform. For conditions (Section 10): (1) ConditionEvaluator supports key=value, key!=value, bare key truthy check, (2) && for AND clauses, (3) outcome key resolves to status.lowercase(), (4) preferred_label key, (5) context.* prefix lookup, (6) bare keys fallback to context lookup. Report IMPLEMENTED or NOT IMPLEMENTED."
    ]

    // ── Gap Summary ───────────────────────────────────────────────────────────
    summarize_gaps [
        label="Summarize All Gaps",
        prompt="Based on all the audit stages above, produce a concise gap report for the coreys-attractor implementation. List only the NOT IMPLEMENTED items grouped by section. For each gap, state: (a) what the spec requires, (b) what the implementation currently does instead. Focus on the following confirmed gaps: (1) CodergenHandler always uses SimulationBackend - real LLM never called even with API keys, (2) default_max_retry graph attribute ignored in RetryPolicy.fromNode, (3) node timeout not enforced in engine execution, (4) auto_status node attribute never checked, (5) loop_restart doesn't re-launch with fresh log directory, (6) checkpoint resume not implemented, (7) ParallelHandler doesn't execute sub-graph traversal for branches, (8) ManagerLoopHandler has no child pipeline autostart. Prioritize by impact."
    ]

    start -> audit_dsl -> audit_engine -> audit_handlers -> audit_state -> audit_human -> audit_lint -> audit_stylesheet -> audit_transforms -> summarize_gaps -> exit
}
